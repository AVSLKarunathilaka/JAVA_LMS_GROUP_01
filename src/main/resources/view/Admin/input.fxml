<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.java_lms_group_01.Controller.InputController">
   <children>

      <VBox alignment="CENTER" spacing="15" AnchorPane.leftAnchor="100.0" AnchorPane.rightAnchor="100.0" AnchorPane.topAnchor="40.0">

         <!-- Title -->
         <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="BMI Calculator" />

         <!-- Unit Selection -->
         <HBox alignment="CENTER" spacing="20">

            <RadioButton fx:id="metricBtn" text="Metric">
               <toggleGroup>
                  <ToggleGroup fx:id="unitGroup" />
               </toggleGroup>
            </RadioButton>

            <RadioButton fx:id="englishBtn" text="English" toggleGroup="$unitGroup" />
         </HBox>

         <!-- Height -->
         <TextField fx:id="heightField" promptText="Enter Height" />

         <!-- Weight -->
         <TextField fx:id="weightField" promptText="Enter Weight" />

         <!-- Calculate Button -->
         <Button fx:id="calculateBtn" onAction="#handleCalculate" prefWidth="150" text="Calculate" />

      </VBox>

   </children>
</AnchorPane>
